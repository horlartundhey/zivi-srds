{
  "version": 2,
  "installCommand": "npm run install:all",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/[...path].js": {
      "includeFiles": "server/**"
    }
  },
  "crons": [
    {
      "path": "/api/email/process",
      "schedule": "0 8 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
